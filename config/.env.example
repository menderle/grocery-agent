# Copy to .env (gitignored). Card numbers NEVER go here — the prepaid card
# lives only as a saved payment method on the HEB account.

GROCERY_AGENT_HOME=~/Claude/grocery-agent

# HEB credentials are stored in the macOS keyring by texas-grocery-mcp,
# not in this file. Set only if running headless on Linux/Docker:
# HEB_USERNAME=
# HEB_KEYRING_BACKEND=keyrings.alt.file.PlaintextKeyring  # Docker only; prefer secrets mount

# Remote MCP gateway (phone access via Tailscale Funnel / Cloudflare tunnel)
MCP_HTTP_PORT=8787

# --- OAuth (how the Claude phone/web connector authenticates you) ---
# Create a Google OAuth app (Cloud Console → Web application). See SETUP.md.
#   OAUTH_BASE_URL: your public https origin, NO /mcp, no trailing slash
#   Register "<OAUTH_BASE_URL>/auth/callback" as the Authorized redirect URI in Google.
# OAUTH_BASE_URL=https://your-machine.your-tailnet.ts.net
# GOOGLE_OAUTH_CLIENT_ID=xxxxx.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=
# OAUTH_ALLOWED_EMAILS=you@gmail.com   # comma-separated; only these may connect

# Static secret for the /list drop-box (Apple Shortcuts/webhooks — can't do OAuth).
# install.sh generates this. Not used for checkout.
LIST_DROP_TOKEN=change-me-long-random-string

# Temporary no-auth TEST mode for the phone connector (only honored with dry-run ON;
# the gateway refuses no-auth when dry-run is off). Leave unset once OAuth works.
# MCP_ALLOW_NO_AUTH=true

# Set true while developing checkout — stops one click before purchase
HEB_CHECKOUT_DRY_RUN=true

# --- Optional intake sources (secrets live here, not in config/*.yaml) ---

# Calendar awareness: comma-separated secret ICS URLs.
# Google Calendar: Settings → your calendar → "Secret address in iCal format".
# iCloud: Calendar app → share calendar → Public Calendar (webcal:// → https://).
# GROCERY_ICS_URLS=

# Todoist: Settings → Integrations → Developer → API token
# TODOIST_API_TOKEN=

# Notion: internal integration token + the page (with a to-do list) shared with it
# NOTION_API_TOKEN=
# NOTION_PAGE_ID=
